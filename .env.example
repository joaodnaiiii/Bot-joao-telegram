# Joazinho Store Bot System - Environment Configuration

# Database Configuration
DATABASE_URL=mysql+mysqlconnector://root:password@localhost/joazinho_store

# Payment Configuration
PUSHINPAY_TOKEN=your_pushinpay_token_here
MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_token_here

# Webhook Configuration
WEBHOOK_URL=https://your-domain.com
WEBHOOK_PORT=5000

# Encryption Key (32 characters)
ENCRYPTION_KEY=joazinho-store-secret-key-2024!

# Optional: Override default settings
# MIN_RECHARGE=2.00
# MAX_RECHARGE=1000.00
# PIX_EXPIRY_MINUTES=10